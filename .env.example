# ── Copy to .env and fill in your values ─────────────────────────────
# cp .env.example .env

# ── Trading mode ──────────────────────────────────────────────────────
# 1 = sandbox / paper trading (safe default)
# 0 = LIVE REAL MONEY — flip this when ready to go live
USE_SANDBOX=1

# ── Tradier ───────────────────────────────────────────────────────────
TRADIER_API_TOKEN=your_production_token_here
TRADIER_API_TOKEN_SANDBOX=your_sandbox_token_here
TRADIER_ACCOUNT_ID=your_account_id_here
TRADIER_BASE_URL=https://api.tradier.com/v1

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ajoy.db

# ── Scheduler ─────────────────────────────────────────────────────────
SCHEDULER_ENABLED=1
SCAN_INTERVAL_SECONDS=60      # entry scan frequency
MANAGE_INTERVAL_SECONDS=10    # open-trade management frequency

# ── Trading session window (America/New_York) ─────────────────────────
TRADING_START_TIME=09:35      # don't enter before this (wait for open volatility to settle)
TRADING_END_TIME=14:45        # close ALL open positions after this (hard cutoff)
LAST_ENTRY_TIME=14:15         # stop NEW entries after this — lets trades breathe before cutoff
MAX_OPEN_TRADES=3             # max concurrent open positions

# ── Position sizing ────────────────────────────────────────────────────
AMOUNT_PER_TRADE=500          # USD budget per trade (option premium, not notional)
MAX_DAILY_LOSS=500            # halt trading for the day if realized P&L drops below -$this

# ── Risk / reward levels ───────────────────────────────────────────────
#
#   Example with entry @ $5.00:
#     risk        = $5.00 × 0.20  = $1.00
#     stop        = $5.00 − $1.00 = $4.00   (−20%)
#     TP1         = $5.00 + $1.00 × 1.5 = $6.50   (+30%)
#     TP2         = $5.00 + $1.00 × 3.0 = $8.00   (+60%)
#     At TP1: sell 50% → stop moves to $5.10 (entry + 2% buffer)
#
STOP_LOSS_PCT=0.20            # fraction of premium at risk (stop = entry × (1 − this))
TP1_MULTIPLIER=1.5            # TP1 = entry + risk × this  →  1.5R reward
TP2_MULTIPLIER=3.0            # TP2 = entry + risk × this  →  3.0R reward
TP1_EXIT_PCT=0.50             # fraction of position to close at TP1 (0.50 = 50%)
BREAKEVEN_BUFFER_PCT=0.02     # after TP1, stop moves to entry × (1 + this)

# ── Strategy params ────────────────────────────────────────────────────
EMA_PERIOD=9
BOUNCE_BARS_REQUIRED=2
VWAP_BAND_PCT=0.002           # 0.2% tolerance band around VWAP for pullback

# ── EMA slope gate ─────────────────────────────────────────────────────
# Rejects entries when the EMA trend is decelerating (spent move).
# Set MIN_EMA_SLOPE_PCT=0 to disable.
MIN_EMA_SLOPE_PCT=0.0001       # 0.01% of EMA per bar minimum momentum required
EMA_SLOPE_LOOKBACK_BARS=3      # measure slope over this many 15-min bars

# ── Indicator thresholds ───────────────────────────────────────────────
RSI_PERIOD=14
RSI_OVERSOLD=45
RSI_OVERBOUGHT=55
VOLUME_SPIKE_MULTIPLIER=2.0
VOLUME_SPIKE_LOOKBACK=20
PCR_BULLISH_ABOVE=1.1
PCR_BEARISH_BELOW=0.9

# ── Option contract selection ──────────────────────────────────────────
OPTION_MIN_DELTA=0.30         # skip deep OTM contracts
OPTION_MAX_DELTA=0.55         # skip deep ITM contracts
OPTION_MIN_VOLUME=10          # skip illiquid contracts

# ── Layer 5: Market regime gate ────────────────────────────────────────
REGIME_GATE_ENABLED=1         # 1 = on (blocks when SPY + stock both oppose signal)
REGIME_GATE_SYMBOL=SPY        # index to use as macro regime proxy
REGIME_GATE_TTL_SECONDS=300   # cache SPY trend for 5 min

# ── Layer 6: IV filter ─────────────────────────────────────────────────
IV_MAX_THRESHOLD=1.50         # skip if ATM IV > 150% (premium too expensive)

# ── Layer 4 tuning ─────────────────────────────────────────────────────
VWAP_SLOPE_LOOKBACK_BARS=20   # compare VWAP now vs N 1-min bars ago
VWAP_SLOPE_THRESHOLD_PCT=0.05 # block if intraday slope |Δ| exceeds 0.05%

# ── Pre-entry guards ───────────────────────────────────────────────────
EARNINGS_SKIP_DAYS=2          # blackout N calendar days before earnings
COOLDOWN_MINUTES=60           # re-entry cooldown after STOP or VWAP_BREAK on symbol
MAX_LOSSES_PER_SYMBOL_PER_DAY=2  # halt entries on symbol after N losing trades/day
MAX_TRADES_PER_SYMBOL_PER_DAY=2  # max total entries per symbol per day (forces diversification)
