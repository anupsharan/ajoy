# Copy to .env and fill in your values
TRADIER_API_TOKEN_SANDBOX="Qj733j2d7UTPTAUJXAGzbyvSpVem"
TRADIER_ACCOUNT_ID_SANDBOX="VA92357805"
TRADIER_BASE_URL_SANDBOX=https://sandbox.tradier.com/v1

TRADIER_BASE_URL=https://api.tradier.com/v1
TRADIER_API_TOKEN="MYSx6GrB71rKDx1XaXmLBbQFZGpD"
TRADIER_ACCOUNT_ID="6YB81397"

# ── Trading mode ──────────────────────────────────────────────────────────
# 1 = sandbox / paper trading (safe default)
# 0 = LIVE REAL MONEY — flip this when ready to go live
USE_SANDBOX=0

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ajoy.db

# ── Scheduler ─────────────────────────────────────────────────────────
SCHEDULER_ENABLED=1
SCAN_INTERVAL_SECONDS=60      # entry scan frequency
MANAGE_INTERVAL_SECONDS=30    # open-trade management frequency

# ── Trading session window (America/New_York) ─────────────────────────
TRADING_START_TIME=11:01
TRADING_END_TIME=15:16
LAST_ENTRY_TIME=12:05
MAX_OPEN_TRADES=2

# ── Position sizing ────────────────────────────────────────────────────
AMOUNT_PER_TRADE=400
MAX_DAILY_LOSS=250

# Fixed-dollar risk sizing: qty = RISK_PER_TRADE / (entry × STOP_LOSS_PCT × 100)
# Every trade risks ~the same $ at its stop. AMOUNT_PER_TRADE still caps premium.
# If 1 contract exceeds either limit the trade is SKIPPED (no more $880 TSLA entries
# on a $450 budget). 120 ≈ old implied risk (450 × 0.27). Set 0 to disable.
RISK_PER_TRADE=120

# Broker-side resting stop order placed after every entry fill — protects the
# position even if the bot process dies. Bot raises it with the trailing stop
# and cancels it before its own exits. Set 0 to disable.
BROKER_STOP_ENABLED=0

# ── Risk / reward levels ───────────────────────────────────────────────
#
#   v1 — simple single-target exits, 100% of position at each level.
#   Example with entry @ $5.00:
#     stop   = $5.00 × (1 − 0.25) = $3.75   (−25%)
#     target = $5.00 × (1 + 0.35) = $6.75   (+35%)
#
STOP_LOSS_PCT=0.2
TAKE_PROFIT_PCT=0.22

# ── Limit order entry ──────────────────────────────────────────────────────
USE_LIMIT_ORDERS=1            # 1 = enter at (bid+ask)/2 via limit; 0 = market at ask
LIMIT_ORDER_TIMEOUT_SECONDS=30   # cancel unfilled limit orders after this many seconds

# ── Trailing stop ──────────────────────────────────────────────────────────
TRAILING_STOP_BREAKEVEN_PCT=0.10           # lock breakeven at 10% gain
TRAILING_STOP_LOCK_PROFIT_PCT=0.02         # Stage 1 stop = entry × 1.02 (locks in 2% for commission)
TRAILING_STOP_TRAIL_PCT=0.16               # start dynamic trail at 16% gain
TRAILING_STOP_TRAIL_FROM_CURRENT_PCT=0.08  # stop = current × (1 − 0.08); trail 8% below current
TRAILING_STOP_MIN_HOLD_MINUTES=15          # don't activate trailing stop until 15 min after entry

# ── Layer 5: Market regime gate (QQQ VWAP position) ───────────────────────
REGIME_GATE_ENABLED=1         # 1 = on; 0 = off (allow all directions regardless of market)
REGIME_GATE_SYMBOL=QQQ        # regime proxy — always QQQ (no circular ref when trading SPY)
REGIME_GATE_TTL_SECONDS=300   # unused (VWAP gate is real-time per scan cycle)
REGIME_VWAP_THRESHOLD=0.002   # 0.2% — QQQ must be this far from its VWAP to declare regime
                               # < threshold → NEUTRAL (allow all); ≥ threshold → BULL/BEAR gate

# ── Layer 6: IV filter ─────────────────────────────────────────────────
IV_MAX_THRESHOLD=1.75         # skip if ATM IV > 150% (too expensive)

# ── Layer 4 tuning ─────────────────────────────────────────────────────
VWAP_SLOPE_LOOKBACK_BARS=20   # compare VWAP now vs N 1-min bars ago
VWAP_SLOPE_THRESHOLD_PCT=0.08 # block if |slope| exceeds 0.05%

# ── VWAP exit band (tighter than entry band) ───────────────────────────
# VWAP_BREAK exit fires when underlying crosses this far past entry VWAP.
# Must be much smaller than VWAP_BAND_PCT (entry) so it fires before the
# hard stop on high-gamma near-expiry options.
# e.g. 0.003 = 0.3% → for $580 SPY, fires at $578.26 below entry VWAP.
VWAP_EXIT_BAND_PCT=0.003

# ── Pre-entry guards ───────────────────────────────────────────────────
COOLDOWN_MINUTES=60
MAX_LOSSES_PER_SYMBOL_PER_DAY=2
MAX_TRADES_PER_SYMBOL_PER_DAY=2

# ── Exit guards ────────────────────────────────────────────────────────────
# Hard stop minimum hold: don't fire the hard stop until this many minutes
# after entry. Lets the trade breathe past initial noise. Quick-loss (below)
# is the emergency brake during this window.
STOP_LOSS_MIN_HOLD_MINUTES=15

# Quick-loss early exit: fires if option drops QUICK_LOSS_PCT within the
# time window [QUICK_LOSS_MIN_HOLD_MINUTES … QUICK_LOSS_MAX_MINUTES].
# Acts as emergency brake while the hard stop is suppressed (first 15 min).
#   MIN_HOLD = quiet period after entry before quick-loss arms (0 = immediate)
#   MAX_MINUTES = upper bound — quick-loss disabled after this many minutes
QUICK_LOSS_PCT=0.25
QUICK_LOSS_MIN_HOLD_MINUTES=14
QUICK_LOSS_MAX_MINUTES=15

TREND_REVERSAL_MIN_HOLD_MINUTES=10
TREND_REVERSAL_CONFIRM_BARS=1
TREND_REVERSAL_COOLDOWN_MINUTES=60

# ── Lunch-hour noise filter ────────────────────────────────────────────
LUNCH_BREAK_ENABLED=1
LUNCH_BREAK_START=12:01       # ET time to stop entries (HH:MM)
LUNCH_BREAK_END=12:28        # ET time to resume entries (HH:MM)

# ── Strategy params ────────────────────────────────────────────────────
EMA_PERIOD=21
BOUNCE_BARS_REQUIRED=2
EMA_CONSECUTIVE_BARS=2
EMA_1M_MIN_MARGIN_PCT=0.001
VWAP_MIN_CLEARANCE_PCT=0.004
VWAP_BAND_PCT=0.0125
TREND_LOOKBACK_DAYS=5         # trading days of 15-min bars to fetch for EMA trend

# ── Adaptive VWAP band (QQQ-based) ────────────────────────────────────────
# QQQ distance from VWAP → effective band applied to all symbol entries:
#   QQQ < 0.5% from VWAP → normal  band (VWAP_BAND_PCT      = 0.9%)
#   QQQ 0.5–1.5%         → relaxed band (VWAP_BAND_RELAXED_PCT = 1.3%)
#   QQQ > 1.5%           → wider   band (VWAP_BAND_WIDER_PCT   = 1.8%)
ADAPTIVE_BAND_ENABLED=0
ADAPTIVE_BAND_SYMBOL=QQQ
ADAPTIVE_BAND_RELAXED_THRESHOLD=0.005
ADAPTIVE_BAND_WIDER_THRESHOLD=0.015
VWAP_BAND_RELAXED_PCT=0.013
VWAP_BAND_WIDER_PCT=0.018

# ── Indicator thresholds ───────────────────────────────────────────────
RSI_PERIOD=14
RSI_OVERSOLD=45
RSI_OVERBOUGHT=55
VOLUME_SPIKE_MULTIPLIER=2.0
VOLUME_SPIKE_LOOKBACK=20
PCR_BULLISH_ABOVE=1.1
PCR_BEARISH_BELOW=0.9

# ── Option contract selection ──────────────────────────────────────────
OPTION_MIN_DELTA=0.30         # skip deep OTM contracts
OPTION_MAX_DELTA=0.55         # skip deep ITM contracts
OPTION_MIN_VOLUME=10          # skip illiquid contracts

TP_COOLDOWN_MINUTES=30

# ══════════════════════════════════════════════════════════════════════════════
# Strategy 2 — EMA Crossover
# ══════════════════════════════════════════════════════════════════════════════
S2_ENABLED=0

# Indicator periods
S2_EMA_FAST=9
S2_EMA_SLOW=21
S2_EMA_TREND=200                    # trend filter EMA on 5-min chart

# Entry guards
S2_VOLUME_CONFIRM=0
S2_COOLDOWN_MINUTES=30

# Risk & sizing
S2_AMOUNT_PER_TRADE=300
S2_RISK_PER_TRADE=200
S2_MAX_OPEN_TRADES=1

# Exit levels
S2_STOP_LOSS_PCT=0.12
S2_STOP_LOSS_MIN_HOLD_MINUTES=0
S2_TAKE_PROFIT_PCT=0.14
S2_BREAKEVEN_PCT=0.10
S2_TRAIL_PCT=0.2
S2_TRAIL_FROM_CURRENT_PCT=0.05

# Trading window (America/New_York, HH:MM)
S2_TRADING_START_TIME=09:45
S2_LAST_ENTRY_TIME=11:00
S2_TRADING_END_TIME=15:30